{% extends 'base.html.twig' %}
{% block title %}Les produits{% endblock %}
{% block body %}
<style>
    @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600&family=Playfair+Display:wght@400;700&display=swap');

    body {
        font-family: 'Montserrat', sans-serif;
        background-color: #f9f9f9;
    }

    h1 {
        text-align: center;
        font-family: 'Playfair Display', serif;
        color: #1a1a1a;
        margin: 3rem 0;
    }

    .card {
        background-color: #ffffff;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
        transition: transform 0.3s;
        margin-bottom: 2rem;
    }

    .card:hover {
        transform: translateY(-5px);
    }

    .card-img-top {
        height: 200px;
        object-fit: cover;
        border-top-left-radius: 8px;
        border-top-right-radius: 8px;
    }

    .card-body {
        padding: 1.5rem;
    }

    .card-title {
        font-family: 'Playfair Display', serif;
        color: #1a1a1a;
        font-size: 1.2rem;
        margin-bottom: 0.5rem;
    }

    .card-text {
        color: #333333;
        font-size: 0.9rem;
    }

    .card h3 {
        color: #d4af37;
        font-weight: 700;
        margin: 1rem 0;
    }

    .btn-outline-primary {
        background-color: #d4af37;
        color: #ffffff;
        border: none;
        border-radius: 4px;
        padding: 0.5rem 1rem;
        font-weight: 600;
    }

    .btn-outline-primary:hover {
        background-color: #e8c86c;
        color: #1a1a1a;
    }
</style>

<div class="container">
    <h1>Nos Produits</h1>
    <div class="row">
        {% for product in products %}
            <div class="col-md-3 mt-4">
                <div class="card">
                    <img src="{{ asset('uploads/images/' ~ product.image) }}" class="card-img-top imgproduct" alt="Image de {{ product.name }}">
                    <div class="card-body">
                        <a class="titleProductLink" href="{{ path('app_home_product_show', {'id': product.id}) }}">
                            <h5 class="card-title">{{ product.name }}</h5>
                        </a>
                        <p class="card-text">{{ product.description|slice(0, 60) }}...</p>
                        <h3>{{ product.price }} €</h3>
                        <a href="{{ path('app_cart_new', {'id': product.id}) }}" class="btn btn-outline-primary">Ajouter au panier</a>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
    {{ knp_pagination_render(products) }}
</div>
{% endblock %}
