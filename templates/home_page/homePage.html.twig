{% extends 'base.html.twig' %}

{% block title %}Catalogue{% endblock %}

{% block body %}

{# ════════════════════════════════════
   HERO SECTION
   ════════════════════════════════════ #}
<section style="
    background: linear-gradient(135deg, #0a0a0a 0%, #110d02 40%, #0a0a0a 100%);
    border-bottom: 1px solid #2a2a2a;
    padding: 5rem 2rem;
    text-align: center;
    position: relative;
    overflow: hidden;
">
    {# Effet de lumière dorée en arrière-plan #}
    <div style="
        position: absolute;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        width: 600px; height: 300px;
        background: radial-gradient(ellipse, rgba(201,168,76,0.07) 0%, transparent 70%);
        pointer-events: none;
    "></div>

    <p class="sb-section-tag">✦ Collection 2026 ✦</p>
    <h1 style="
        font-family: var(--font-display);
        font-size: clamp(2.5rem, 6vw, 4.5rem);
        font-weight: 300;
        color: var(--white);
        margin-bottom: 1rem;
        letter-spacing: 2px;
    ">
        L'Art du <em style="color: var(--gold); font-style: italic;">Style</em>
    </h1>
    <p style="color: var(--white-dim); font-size: 0.9rem; letter-spacing: 2px; margin-bottom: 2rem; max-width: 480px; margin-left: auto; margin-right: auto;">
        Des pièces sélectionnées avec soin — Nike, Adidas, Levi's, Puma et bien plus
    </p>
    <a href="#catalogue" class="btn-gold">
        <i class="fas fa-arrow-down"></i> Découvrir la collection
    </a>
</section>

{# ════════════════════════════════════
   CATALOGUE PRODUITS
   ════════════════════════════════════ #}
<section id="catalogue" style="padding: 4rem 2rem; max-width: 1400px; margin: 0 auto;">

    <div style="text-align:center; margin-bottom: 3rem;">
        <p class="sb-section-tag">— Nos Produits —</p>
        <h2 class="sb-section-title">Collection Complète</h2>
        <div class="sb-divider"></div>
    </div>

    {# Grille de produits #}
    <div style="
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 1.5rem;
    ">
        {% for product in products %}
            <div class="sb-card">

                {# Image du produit #}
                <div style="overflow: hidden; position: relative;">
                    <img
                        src="{{ asset('uploads/images/' ~ product.image) }}"
                        alt="{{ product.name }}"
                        class="sb-card-img"
                    >
                    {# Badge stock faible #}
                    {% if product.stock <= 3 and product.stock > 0 %}
                        <span class="sb-badge sb-badge-gold" style="position:absolute; top:12px; right:12px;">
                            Dernières pièces
                        </span>
                    {% elseif product.stock == 0 %}
                        <span class="sb-badge sb-badge-danger" style="position:absolute; top:12px; right:12px;">
                            Épuisé
                        </span>
                    {% endif %}
                </div>

                {# Contenu de la card #}
                <div class="sb-card-body">
                    <a href="{{ path('app_home_product_show', {'id': product.id}) }}" style="text-decoration:none;">
                        <h3 class="sb-card-title">{{ product.name }}</h3>
                    </a>

                    {% if product.description %}
                        <p class="sb-card-desc">{{ product.description|slice(0, 70) }}...</p>
                    {% endif %}

                    <div style="display:flex; justify-content:space-between; align-items:center; margin-top:1rem;">
                        <span class="sb-card-price">{{ product.price }} €</span>

                        {% if product.stock > 0 %}
                            <a href="{{ path('app_cart_new', {'id': product.id}) }}" class="btn-gold" style="padding: 8px 16px; font-size: 0.7rem;">
                                <i class="fas fa-plus"></i> Panier
                            </a>
                        {% else %}
                            <span style="color: var(--white-dim); font-size: 0.75rem; letter-spacing: 1px;">ÉPUISÉ</span>
                        {% endif %}
                    </div>
                </div>

            </div>
        {% else %}
            <div style="grid-column: 1/-1; text-align:center; padding: 4rem; color: var(--white-dim);">
                <i class="fas fa-box-open" style="font-size: 3rem; color: var(--gold); margin-bottom: 1rem; display:block;"></i>
                <p style="font-family: var(--font-display); font-size: 1.5rem;">Aucun produit disponible</p>
            </div>
        {% endfor %}
    </div>

    {# Pagination #}
    {% if products is defined and products.count > 0 %}
        <div style="margin-top: 3rem; display: flex; justify-content: center;">
            {{ knp_pagination_render(products) }}
        </div>
    {% endif %}

</section>

{% endblock %}
