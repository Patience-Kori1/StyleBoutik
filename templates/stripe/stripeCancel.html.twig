{% extends 'base.html.twig' %}
{% block title %}Paiement annulé{% endblock %}
{% block body %}
<div style="min-height:70vh;display:flex;align-items:center;justify-content:center;padding:3rem 1.5rem;">
    <div style="text-align:center;max-width:480px;">
        <div style="
            width:80px;height:80px;border-radius:50%;
            background:rgba(192,57,43,.1);border:2px solid var(--danger);
            display:flex;align-items:center;justify-content:center;
            margin:0 auto 2rem;
        ">
            <i class="fas fa-times" style="font-size:2rem;color:#e07065;"></i>
        </div>
        <p class="sb-section-tag">— Paiement non abouti —</p>
        <h1 style="font-size:2.5rem;font-weight:300;margin-bottom:1rem;">Paiement annulé</h1>
        <div style="width:60px;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);margin:1rem auto 1.5rem;"></div>
        <p style="color:var(--white-dim);margin-bottom:2rem;line-height:1.8;">
            Votre paiement n'a pas été finalisé.<br>
            Votre panier a été conservé. Vous pouvez réessayer quand vous le souhaitez.
        </p>
        <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
            <a href="{{ path('app_cart') }}" class="btn-gold filled">
                <i class="fas fa-shopping-bag"></i> Retour au panier
            </a>
            <a href="{{ path('app_home_page') }}" class="btn-gold">
                <i class="fas fa-arrow-left"></i> Accueil
            </a>
        </div>
    </div>
</div>
{% endblock %}
