{% extends 'base.html.twig' %}
{% block title %}Historique stock — {{ product.name }}{% endblock %}

{% block body %}
<div style="max-width:800px;margin:0 auto;padding:3rem 1.5rem;">

    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:2rem;flex-wrap:wrap;gap:1rem;">
        <div>
            <p class="sb-section-tag" style="text-align:left;">— Historique —</p>
            <h1 style="font-family:var(--font-display);font-size:1.8rem;font-weight:300;">
                Stock : {{ product.name }}
            </h1>
        </div>
        <div style="display:flex;gap:.75rem;">
            <a href="{{ path('app_product_stock_add', {'id': product.id}) }}" class="btn-gold">
                <i class="fas fa-plus"></i> Ajouter stock
            </a>
            <a href="{{ path('app_product_index') }}" class="btn-gold">
                <i class="fas fa-arrow-left"></i> Retour
            </a>
        </div>
    </div>

    {# Stock actuel #}
    <div style="background:var(--gold-subtle);border:1px solid var(--gold);padding:1rem 1.5rem;margin-bottom:2rem;display:flex;justify-content:space-between;align-items:center;">
        <span style="font-size:.75rem;letter-spacing:2px;text-transform:uppercase;color:var(--white-muted);">Stock actuel</span>
        <span style="font-family:var(--font-display);font-size:1.8rem;color:var(--gold);font-weight:300;">
            {{ product.stock }} unité{{ product.stock > 1 ? 's' : '' }}
        </span>
    </div>

    {% if productsAdded|length > 0 %}
        <div style="border:1px solid var(--black-border);">
            <table class="sb-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Date d'ajout</th>
                        <th>Quantité ajoutée</th>
                    </tr>
                </thead>
                <tbody>
                    {% for history in productsAdded %}
                        <tr>
                            <td style="color:var(--white-dim);font-size:.8rem;">{{ loop.index }}</td>
                            <td>{{ history.createdAt|date('d/m/Y à H:i') }}</td>
                            <td>
                                <span class="sb-badge sb-badge-success">
                                    +{{ history.quantity }}
                                </span>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% else %}
        <div style="text-align:center;padding:3rem;border:1px solid var(--black-border);">
            <i class="fas fa-history" style="font-size:2rem;color:var(--gold);display:block;margin-bottom:1rem;opacity:.4;"></i>
            <p style="color:var(--white-dim);">Aucun historique d'approvisionnement disponible.</p>
        </div>
    {% endif %}
</div>
{% endblock %}
