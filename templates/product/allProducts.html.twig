{% extends 'base.html.twig' %}
{% block title %}Gestion des produits{% endblock %}

{% block body %}
<div style="max-width:1200px;margin:0 auto;padding:3rem 1.5rem;">

    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:2rem;flex-wrap:wrap;gap:1rem;">
        <div>
            <p class="sb-section-tag" style="text-align:left;margin-bottom:4px;">— Espace éditeur —</p>
            <h1 style="font-family:var(--font-display);font-size:2rem;font-weight:300;">Gestion des produits</h1>
        </div>
        <a href="{{ path('app_product_new') }}" class="btn-gold filled">
            <i class="fas fa-plus"></i> Nouveau produit
        </a>
    </div>

    <div style="border:1px solid var(--black-border);overflow:hidden;">
        <table class="sb-table">
            <thead>
                <tr>
                    <th style="width:80px;">Image</th>
                    <th>Produit</th>
                    <th>Prix</th>
                    <th>Stock</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for product in products %}
                    <tr>
                        <td>
                            <img src="{{ asset('uploads/images/' ~ product.image) }}"
                                 alt="{{ product.name }}"
                                 style="width:60px;height:60px;object-fit:cover;border:1px solid var(--black-border);">
                        </td>
                        <td>
                            <div style="font-family:var(--font-display);font-size:1.05rem;color:var(--white);margin-bottom:4px;">
                                {{ product.name }}
                            </div>
                            {% if product.description %}
                                <div style="font-size:.78rem;color:var(--white-dim);">
                                    {{ product.description|slice(0,60) }}...
                                </div>
                            {% endif %}
                        </td>
                        <td>
                            <span style="font-family:var(--font-display);font-size:1.1rem;color:var(--gold);">
                                {{ product.price }} €
                            </span>
                        </td>
                        <td>
                            {% if product.stock > 5 %}
                                <span class="sb-badge sb-badge-success">{{ product.stock }}</span>
                            {% elseif product.stock > 0 %}
                                <span class="sb-badge sb-badge-gold">{{ product.stock }}</span>
                            {% else %}
                                <span class="sb-badge sb-badge-danger">Épuisé</span>
                            {% endif %}
                        </td>
                        <td>
                            <div style="display:flex;gap:.5rem;flex-wrap:wrap;">
                                <a href="{{ path('app_product_show', {'id': product.id}) }}" class="btn-gold" style="padding:6px 12px;font-size:.68rem;">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a href="{{ path('app_product_edit', {'id': product.id}) }}" class="btn-gold" style="padding:6px 12px;font-size:.68rem;">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a href="{{ path('app_product_stock_add', {'id': product.id}) }}" class="btn-gold" style="padding:6px 12px;font-size:.68rem;" title="Ajouter stock">
                                    <i class="fas fa-plus-circle"></i>
                                </a>
                                <a href="{{ path('app_product_stock_add_history', {'id': product.id}) }}" class="btn-gold" style="padding:6px 12px;font-size:.68rem;" title="Historique stock">
                                    <i class="fas fa-history"></i>
                                </a>
                                {{ include('product/_delete_form.html.twig') }}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" style="text-align:center;padding:3rem;color:var(--white-dim);">
                            Aucun produit enregistré.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
