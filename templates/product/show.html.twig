{% extends 'base.html.twig' %}
{% block title %}{{ product.name }} — Admin{% endblock %}

{% block body %}
<div style="max-width:900px;margin:0 auto;padding:3rem 1.5rem;">

    <div style="margin-bottom:2rem;">
        <p class="sb-section-tag" style="text-align:left;">— Détail produit —</p>
        <h1 style="font-family:var(--font-display);font-size:2rem;font-weight:300;">{{ product.name }}</h1>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1.5fr;gap:2rem;margin-bottom:2rem;">
        <img src="{{ asset('uploads/images/' ~ product.image) }}"
             alt="{{ product.name }}"
             style="width:100%;height:300px;object-fit:cover;border:1px solid var(--black-border);">

        <div style="background:var(--black-card);border:1px solid var(--black-border);padding:1.5rem;">
            <table style="width:100%;border-collapse:collapse;">
                {% set rows = [
                    {'label': 'Nom', 'value': product.name},
                    {'label': 'Prix', 'value': product.price ~ ' €'},
                    {'label': 'Stock', 'value': product.stock},
                ] %}
                {% for row in rows %}
                    <tr style="border-bottom:1px solid var(--black-border);">
                        <td style="padding:12px 0;font-size:.72rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--gold);width:120px;">
                            {{ row.label }}
                        </td>
                        <td style="padding:12px 0;color:var(--white-muted);font-size:.9rem;">
                            {{ row.value }}
                        </td>
                    </tr>
                {% endfor %}
                {% if product.description %}
                    <tr>
                        <td style="padding:12px 0;font-size:.72rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--gold);vertical-align:top;">
                            Description
                        </td>
                        <td style="padding:12px 0;color:var(--white-muted);font-size:.85rem;line-height:1.7;">
                            {{ product.description }}
                        </td>
                    </tr>
                {% endif %}
            </table>
        </div>
    </div>

    <div style="display:flex;gap:.75rem;flex-wrap:wrap;">
        <a href="{{ path('app_product_edit', {'id': product.id}) }}" class="btn-gold">
            <i class="fas fa-edit"></i> Modifier
        </a>
        <a href="{{ path('app_product_stock_add', {'id': product.id}) }}" class="btn-gold">
            <i class="fas fa-plus-circle"></i> Ajouter stock
        </a>
        <a href="{{ path('app_product_stock_add_history', {'id': product.id}) }}" class="btn-gold">
            <i class="fas fa-history"></i> Historique stock
        </a>
        <a href="{{ path('app_product_index') }}" class="btn-gold">
            <i class="fas fa-arrow-left"></i> Retour
        </a>
        {{ include('product/_delete_form.html.twig') }}
    </div>
</div>
{% endblock %}
