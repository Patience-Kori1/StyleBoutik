{% extends 'base.html.twig' %}
{% block title %}Modifier — {{ product.name }}{% endblock %}

{% block body %}
<div style="max-width:700px;margin:0 auto;padding:3rem 1.5rem;">

    <div style="margin-bottom:2rem;">
        <p class="sb-section-tag" style="text-align:left;">— Espace éditeur —</p>
        <h1 style="font-family:var(--font-display);font-size:2rem;font-weight:300;">
            Modifier : {{ product.name }}
        </h1>
    </div>

    {# Aperçu image actuelle #}
    {% if product.image %}
        <div style="margin-bottom:1.5rem;display:flex;align-items:center;gap:1rem;">
            <img src="{{ asset('uploads/images/' ~ product.image) }}"
                 alt="{{ product.name }}"
                 style="width:80px;height:80px;object-fit:cover;border:1px solid var(--gold);">
            <div>
                <p style="font-size:.75rem;letter-spacing:1px;color:var(--white-muted);">Image actuelle</p>
                <p style="font-size:.8rem;color:var(--white-dim);">{{ product.image }}</p>
            </div>
        </div>
    {% endif %}

    <div style="background:var(--black-card);border:1px solid var(--black-border);padding:2rem;">
        {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}

        <div style="display:flex;flex-direction:column;gap:1.25rem;">

            <div>
                <label class="sb-form-label"><i class="fas fa-tag" style="color:var(--gold);margin-right:6px;"></i>Nom du produit</label>
                {{ form_widget(form.name, {'attr': {'class': 'sb-form-control'}}) }}
                {{ form_errors(form.name) }}
            </div>

            <div>
                <label class="sb-form-label"><i class="fas fa-align-left" style="color:var(--gold);margin-right:6px;"></i>Description</label>
                {{ form_widget(form.description, {'attr': {'class': 'sb-form-control', 'rows': '4', 'style': 'resize:vertical;min-height:100px;'}}) }}
                {{ form_errors(form.description) }}
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
                <div>
                    <label class="sb-form-label"><i class="fas fa-euro-sign" style="color:var(--gold);margin-right:6px;"></i>Prix (€)</label>
                    {{ form_widget(form.price, {'attr': {'class': 'sb-form-control'}}) }}
                    {{ form_errors(form.price) }}
                </div>
                <div>
                    <label class="sb-form-label"><i class="fas fa-image" style="color:var(--gold);margin-right:6px;"></i>Nouvelle image</label>
                    {{ form_widget(form.image, {'attr': {'class': 'sb-form-control', 'style': 'padding:10px;cursor:pointer;'}}) }}
                    {{ form_errors(form.image) }}
                </div>
            </div>

            <div style="display:flex;gap:1rem;margin-top:.5rem;">
                <button type="submit" class="btn-gold filled" style="flex:1;justify-content:center;padding:13px;">
                    <i class="fas fa-save"></i> Enregistrer les modifications
                </button>
                <a href="{{ path('app_product_index') }}" class="btn-gold" style="padding:13px 20px;">
                    <i class="fas fa-times"></i>
                </a>
            </div>

        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
