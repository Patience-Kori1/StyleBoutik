{% extends 'base.html.twig' %}
{% block title %}Sous-catégories{% endblock %}

{% block body %}
<div style="max-width:900px;margin:0 auto;padding:3rem 1.5rem;">

    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:2rem;flex-wrap:wrap;gap:1rem;">
        <div>
            <p class="sb-section-tag" style="text-align:left;">— Admin —</p>
            <h1 style="font-family:var(--font-display);font-size:2rem;font-weight:300;">Sous-catégories</h1>
        </div>
        <a href="{{ path('app_sub_category_new') }}" class="btn-gold filled">
            <i class="fas fa-plus"></i> Nouvelle sous-catégorie
        </a>
    </div>

    <div style="border:1px solid var(--black-border);">
        <table class="sb-table">
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Catégorie parente</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for subCategory in sub_categories %}
                    <tr>
                        <td style="color:var(--white);">{{ subCategory.name }}</td>
                        <td>
                            <span class="sb-badge sb-badge-gold">{{ subCategory.category.name }}</span>
                        </td>
                        <td>
                            <div style="display:flex;gap:.5rem;">
                                <a href="{{ path('app_sub_category_edit', {'id': subCategory.id}) }}" class="btn-gold" style="padding:6px 12px;font-size:.68rem;">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a href="{{ path('app_sub_category_delete', {'id': subCategory.id}) }}"
                                   class="btn-danger-sb" style="padding:6px 12px;font-size:.68rem;"
                                   onclick="return confirm('Supprimer cette sous-catégorie ?')">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="3" style="text-align:center;padding:2rem;color:var(--white-dim);">Aucune sous-catégorie.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
