{# layouts/footer.html.twig — StyleBoutik #}
<footer style="
    background: var(--black-soft);
    border-top: 1px solid var(--black-border);
    padding: 2rem 1.5rem;
    margin-top: 4rem;
    text-align: center;
">
    {# Ligne dorée décorative #}
    <div style="
        width: 80px; height: 1px;
        background: linear-gradient(90deg, transparent, var(--gold), transparent);
        margin: 0 auto 1.5rem;
    "></div>

    <p style="
        font-family: var(--font-display);
        font-size: 1.4rem;
        font-weight: 300;
        color: var(--gold);
        letter-spacing: 4px;
        margin-bottom: .5rem;
    ">StyleBoutik</p>

    <p style="color: var(--white-dim); font-size: .75rem; letter-spacing: 1.5px; margin-bottom: 1rem;">
        VOTRE BOUTIQUE PREMIUM EN LIGNE
    </p>

    <div style="display:flex; justify-content:center; gap:1.5rem; margin-bottom:1rem;">
        <a href="{{ path('app_home_page') }}" style="color:var(--white-dim);font-size:.75rem;letter-spacing:1px;text-transform:uppercase;">Accueil</a>
        <a href="{{ path('app_cart') }}" style="color:var(--white-dim);font-size:.75rem;letter-spacing:1px;text-transform:uppercase;">Panier</a>
        <a href="{{ path('app_login') }}" style="color:var(--white-dim);font-size:.75rem;letter-spacing:1px;text-transform:uppercase;">Connexion</a>
    </div>

    <p style="color: var(--white-dim); font-size: .72rem; letter-spacing: .5px;">
        © 2026 <span style="color:var(--gold);">StyleBoutik</span> — Tous droits réservés
    </p>
</footer>
