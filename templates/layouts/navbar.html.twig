{# ==========================================================
   layouts/navbar.html.twig — StyleBoutik
   Utilise 'all_categories' injectée par AppGlobalsExtension
   Catégories : visibles par tous
   Commandes : ROLE_EDITOR ou ROLE_ADMIN uniquement
   ========================================================== #}
<style>
    .sb-navbar {
        background: var(--black-soft);
        border-bottom: 1px solid var(--black-border);
        position: sticky; top: 0; z-index: 1000;
        position: relative;
    }
    .sb-navbar .container-fluid { padding: 0 1.5rem; }
    .sb-navbar-inner {
        display: flex; align-items: center;
        justify-content: space-between;
        height: 64px; gap: 1rem;
        max-width: 1400px; 
        margin: 0 auto;     
        padding: 0 1.5rem;  
    }
    .sb-logo {
        font-family: var(--font-display);
        font-size: 1.75rem; font-weight: 600;
        color: var(--gold) !important;
        letter-spacing: 2px; white-space: nowrap;
        text-decoration: none; flex-shrink: 0;
        transition: var(--transition);
    }
    .sb-logo:hover { color: var(--gold-light) !important; }
    .sb-nav {
        display: flex; align-items: center;
        gap: 0; list-style: none; margin: 0; padding: 0; flex: 1;
    }
    .sb-nav .nav-item { position: relative; }
    .sb-nav .nav-link {
        display: flex; align-items: center; gap: 6px;
        padding: 0 14px; height: 64px;
        color: var(--white-muted) !important;
        font-size: .76rem; font-weight: 500;
        letter-spacing: 1.5px; text-transform: uppercase;
        text-decoration: none; white-space: nowrap;
        transition: var(--transition);
    }
    .sb-nav .nav-link:hover { color: var(--gold) !important; }
    .sb-nav .nav-link.gold { color: var(--gold) !important; }
    .sb-nav .nav-link .chevron { font-size: .55rem; margin-left: 2px; }
    .sb-dropdown {
        position: absolute; top: 100%; left: 0;
        min-width: 230px;
        background: var(--black-soft);
        border: 1px solid var(--black-border);
        border-top: 2px solid var(--gold);
        padding: .5rem 0;
        opacity: 0; visibility: hidden;
        transform: translateY(-6px);
        transition: var(--transition); z-index: 1001;
    }
    .sb-nav .nav-item:hover .sb-dropdown {
        opacity: 1; visibility: visible; transform: translateY(0);
    }
    .sb-dropdown .dd-item {
        display: flex; align-items: center; gap: 10px;
        padding: 10px 18px;
        color: var(--white-muted) !important;
        font-size: .8rem; letter-spacing: .5px;
        transition: var(--transition); text-decoration: none;
    }
    .sb-dropdown .dd-item:hover { color: var(--gold) !important; background: var(--gold-subtle); }
    .sb-dropdown .dd-item.sub { padding-left: 36px; font-size: .75rem; color: var(--white-dim) !important; }
    .sb-dropdown .dd-divider { border: none; border-top: 1px solid var(--black-border); margin: 4px 0; }
    .sb-dropdown .dd-item i { color: var(--gold); font-size: .7rem; width: 14px; }
    .sb-search { display: flex; align-items: center; flex-shrink: 0; }
    .sb-search input {
        background: var(--black-card);
        border: 1px solid var(--black-border); border-right: none;
        color: var(--white); padding: 8px 14px;
        font-family: var(--font-body); font-size: .8rem; width: 200px;
        outline: none; transition: var(--transition);
    }
    .sb-search input:focus { border-color: var(--gold); }
    .sb-search input::placeholder { color: var(--white-dim); }
    .sb-search button {
        background: var(--gold); border: none; color: var(--black);
        padding: 8px 14px; font-size: .75rem; cursor: pointer;
        transition: var(--transition); white-space: nowrap;
    }
    .sb-search button:hover { background: var(--gold-light); }
    .sb-cart {
        color: var(--gold); font-size: 1.1rem; padding: 0 6px;
        flex-shrink: 0; transition: var(--transition); text-decoration: none;
    }
    .sb-cart:hover { color: var(--gold-light) !important; }
    .sb-toggler {
        display: none; background: none;
        border: 1px solid var(--black-border);
        color: var(--gold); padding: 6px 10px; cursor: pointer; font-size: 1rem;
    }
    @media (max-width: 992px) {
        .sb-nav { display: none; }
        .sb-toggler { display: block; }
        .sb-search input { width: 130px; }
        /* Quand Bootstrap ouvre le collapse */
        .sb-nav.show {
            display: flex !important;
            flex-direction: column;
            width: 100%;
            background: var(--black-soft);
            border-top: 1px solid var(--black-border);
            padding: .5rem 0;
            position: absolute;
            top: 64px;
            left: 0;
            right: 0;
            z-index: 999;
        }

        .sb-nav.show .nav-link {
            height: auto;
            padding: 12px 20px;
            border-bottom: 1px solid var(--black-border);
        }
    }
</style>

<nav class="sb-navbar">
    <div class="container-fluid">
        <div class="sb-navbar-inner">

            <a href="{{ path('app_home_page') }}" class="sb-logo">StyleBoutik</a>

            <button class="sb-toggler" data-bs-toggle="collapse" data-bs-target="#sbNavMenu">
                <i class="fas fa-bars"></i>
            </button>

            <ul class="sb-nav" id="sbNavMenu">

                {# Accueil — tous #}
                <li class="nav-item">
                    <a href="{{ path('app_home_page') }}" class="nav-link">
                        <i class="fas fa-home"></i> Accueil
                    </a>
                </li>

                {# ── Catégories — tous les visiteurs
                     all_categories vient de App\Twig\AppGlobalsExtension
                     disponible sur toutes les pages sans passer par le contrôleur ── #}
                <li class="nav-item">
                    <a href="#" class="nav-link">
                        <i class="fas fa-layer-group"></i> Catégories
                        <i class="fas fa-chevron-down chevron"></i>
                    </a>
                    <div class="sb-dropdown">
                        {% if all_categories is defined and all_categories|length > 0 %}
                            {% for category in all_categories %}
                                <a class="dd-item" style="cursor:default; opacity:.7;">
                                    <i class="fas fa-circle"></i> {{ category.name }}
                                </a>
                                {% for subCategory in category.subCategories %}
                                    <a href="{{ path('app_home_product_filter', {'id': subCategory.id}) }}" class="dd-item sub">
                                        <i class="fas fa-angle-right"></i> {{ subCategory.name }}
                                    </a>
                                {% endfor %}
                                <hr class="dd-divider">
                            {% endfor %}
                        {% else %}
                            <span class="dd-item" style="color:var(--white-dim);cursor:default;">
                                <i class="fas fa-info-circle"></i> Aucune catégorie
                            </span>
                        {% endif %}
                    </div>
                </li>

                {# ── Admin — ROLE_ADMIN uniquement ── #}
                {% if is_granted('ROLE_ADMIN') %}
                    <li class="nav-item">
                        <a href="#" class="nav-link gold">
                            <i class="fas fa-crown"></i> Admin
                            <i class="fas fa-chevron-down chevron"></i>
                        </a>
                        <div class="sb-dropdown">
                            <a href="{{ path('app_allCategories') }}" class="dd-item"><i class="fas fa-folder"></i> Catégories</a>
                            <a href="{{ path('app_category_new') }}" class="dd-item"><i class="fas fa-plus"></i> Nouvelle catégorie</a>
                            <hr class="dd-divider">
                            <a href="{{ path('app_sub_category_index') }}" class="dd-item"><i class="fas fa-folder-open"></i> Sous-catégories</a>
                            <hr class="dd-divider">
                            <a href="{{ path('app_product_index') }}" class="dd-item"><i class="fas fa-tshirt"></i> Produits</a>
                            <a href="{{ path('app_product_new') }}" class="dd-item"><i class="fas fa-plus"></i> Nouveau produit</a>
                            <hr class="dd-divider">
                            <a href="{{ path('app_user') }}" class="dd-item"><i class="fas fa-users"></i> Utilisateurs</a>
                            <hr class="dd-divider">
                            <a href="{{ path('app_orders_show', {'type': 'all'}) }}" class="dd-item"><i class="fas fa-history"></i> Toutes les commandes</a>
                        </div>
                    </li>
                {% endif %}

                {# ── Éditeur — ROLE_EDITOR uniquement (pas admin) ── #}
                {% if is_granted('ROLE_EDITOR') and not is_granted('ROLE_ADMIN') %}
                    <li class="nav-item">
                        <a href="#" class="nav-link">
                            <i class="fas fa-edit"></i> Éditeur
                            <i class="fas fa-chevron-down chevron"></i>
                        </a>
                        <div class="sb-dropdown">
                            <a href="{{ path('app_product_index') }}" class="dd-item"><i class="fas fa-tshirt"></i> Mes produits</a>
                            <a href="{{ path('app_product_new') }}" class="dd-item"><i class="fas fa-plus"></i> Nouveau produit</a>
                            <hr class="dd-divider">
                            <a href="{{ path('app_orders_show', {'type': 'all'}) }}" class="dd-item"><i class="fas fa-history"></i> Commandes</a>
                        </div>
                    </li>
                {% endif %}

                {# ── Commandes — ROLE_EDITOR ou ROLE_ADMIN seulement ── #}
                {% if is_granted('ROLE_EDITOR') or is_granted('ROLE_ADMIN') %}
                    <li class="nav-item">
                        <a href="#" class="nav-link">
                            <i class="fas fa-clipboard-list"></i> Commandes
                            <i class="fas fa-chevron-down chevron"></i>
                        </a>
                        <div class="sb-dropdown">
                            <a href="{{ path('app_orders_show', {'type': 'all'}) }}" class="dd-item"><i class="fas fa-list"></i> Toutes</a>
                            <a href="{{ path('app_orders_show', {'type': 'is-completed'}) }}" class="dd-item"><i class="fas fa-check-circle"></i> Livrées</a>
                            <a href="{{ path('app_orders_show', {'type': 'is-not-completed'}) }}" class="dd-item"><i class="fas fa-times-circle"></i> Non livrées</a>
                            <hr class="dd-divider">
                            <a href="{{ path('app_orders_show', {'type': 'pay-on-stripe-is-delivered'}) }}" class="dd-item"><i class="fas fa-credit-card"></i> Stripe livrées</a>
                            <a href="{{ path('app_orders_show', {'type': 'pay-on-stripe-not-delivered'}) }}" class="dd-item"><i class="fas fa-credit-card"></i> Stripe non livrées</a>
                        </div>
                    </li>
                {% endif %}

                {# ── Visiteur non connecté ── #}
                {% if app.user is null %}
                    <li class="nav-item">
                        <a href="{{ path('app_register') }}" class="nav-link">
                            <i class="fas fa-user-plus"></i> S'inscrire
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('app_login') }}" class="nav-link gold">
                            <i class="fas fa-sign-in-alt"></i> Connexion
                        </a>
                    </li>
                {% endif %}

                {# ── Connecté ── #}
                {% if app.user is not null %}
                    <li class="nav-item">
                        <a href="{{ path('app_logout') }}" class="nav-link">
                            <i class="fas fa-sign-out-alt"></i> Déconnexion
                        </a>
                    </li>
                {% endif %}

            </ul>

            <div style="display:flex;align-items:center;gap:.75rem;flex-shrink:0;">
                <a href="{{ path('app_cart') }}" class="sb-cart">
                    <i class="fas fa-shopping-bag"></i>
                </a>
                <form data-turbo="false" method="GET" action="{{ path('app_search_engine') }}" class="sb-search">
                    <input type="search" name="word" placeholder="Rechercher..." aria-label="Recherche">
                    <button type="submit"><i class="fas fa-search"></i></button>
                </form>
            </div>

        </div>
    </div>
</nav>
