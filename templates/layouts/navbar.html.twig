<nav class="navbar navbar-expand-lg" style="
    background-color: #1a1a1a;
    font-family: 'Montserrat', sans-serif;
    padding: 0.5rem 1rem;
    border-bottom: 1px solid #333;
">
    <div class="container-fluid">
        <!-- Logo + Panier (à gauche) -->
        <div class="d-flex align-items-center">
            <a class="navbar-brand me-4" href="{{ path('app_home_page') }}" style="
                font-family: 'Playfair Display', serif;
                font-size: 24px;
                color: #d4af37 !important;
                font-weight: 700;
            ">StyleBoutik</a>
            <!-- Icône Panier avec badge (exemple : 3 articles) -->
            
        </div>

        <!-- Bouton toggler (mobile) -->
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarColor01" aria-controls="navbarColor01" aria-expanded="false" aria-label="Toggle navigation" style="border-color: #d4af37;">
            <span class="navbar-toggler-icon"></span>
        </button>

        <!-- Menu principal -->
        <div class="collapse navbar-collapse" id="navbarColor01">
            <ul class="navbar-nav me-auto my-2 my-lg-0 navbar-nav-scroll">
                <!-- Lien Accueil avec icône -->
                <li class="nav-item">
                    <a class="nav-link" aria-current="page" href="{{ path('app_home_page') }}" style="color: #ffffff; font-weight: 500;">
                        <i class="fas fa-home me-1"></i> Accueil
                    </a>
                </li>

                <!-- Dropdown Catégories avec icône -->
                {% if categories is defined %}
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="{{ path('app_allCategories') }}" data-bs-toggle="dropdown" role="button" aria-haspopup="true" aria-expanded="false" style="color: #ffffff; font-weight: 500;">
                            <i class="fas fa-list me-1"></i> Catégories
                        </a>
                        <ul class="dropdown-menu" style="background-color: #1a1a1a; border: none;">
                            {% for category in categories %}
                                <li><a class="dropdown-item" href="{{ path('app_allCategories') }}" style="color: #ffffff;"><i class="fas fa-tag me-2"></i>{{ category.name }}</a></li>
                                {% for subCategory in category.subCategories %}
                                    <li><a class="dropdown-item" href="{{ path('app_home_product_filter', {'id': subCategory.id}) }}" style="color: #ffffff; padding-left: 2rem;"><i class="fas fa-angle-right me-2"></i>{{ subCategory.name }}</a></li>
                                {% endfor %}
                                <li><hr class="dropdown-divider" style="border-color: #333;"></li>
                            {% endfor %}
                        </ul>
                    </li>
                {% endif %}

                <!-- Section Admin (si ROLE_ADMIN) avec icône -->
                {% if is_granted('ROLE_ADMIN') %}
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#" role="button" aria-haspopup="true" aria-expanded="false" style="color: #ffffff; font-weight: 500;">
                            <i class="fas fa-user-shield me-1"></i> Admin
                        </a>
                        <ul class="dropdown-menu" style="background-color: #1a1a1a; border: none;">
                            <li><a class="dropdown-item" href="{{ path('app_allCategories') }}" style="color: #ffffff;"><i class="fas fa-box me-2"></i>Les catégories</a></li>
                            <li><a class="dropdown-item" href="{{ path('app_category_new') }}" style="color: #ffffff;"><i class="fas fa-plus me-2"></i>Ajouter une catégorie</a></li>
                            <li><hr class="dropdown-divider" style="border-color: #333;"></li>
                            <li><a class="dropdown-item" href="{{ path('app_sub_category_index') }}" style="color: #ffffff;"><i class="fas fa-boxes me-2"></i>Sous-catégories</a></li>
                            <li><a class="dropdown-item" href="#" style="color: #ffffff;"><i class="fas fa-plus me-2"></i>Ajouter une sous-catégorie</a></li>
                            <li><hr class="dropdown-divider" style="border-color: #333;"></li>
                            <li><a class="dropdown-item" href="{{ path('app_product_index') }}" style="color: #ffffff;"><i class="fas fa-tshirt me-2"></i>Les produits</a></li>
                            <li><a class="dropdown-item" href="{{ path('app_product_new') }}" style="color: #ffffff;"><i class="fas fa-plus me-2"></i>Ajouter un produit</a></li>
                            <li><hr class="dropdown-divider" style="border-color: #333;"></li>
                            <li><a class="dropdown-item" href="{{ path('app_user') }}" style="color: #ffffff;"><i class="fas fa-users me-2"></i>Utilisateurs</a></li>
                            <li><hr class="dropdown-divider" style="border-color: #333;"></li>
                            <li><a class="dropdown-item" href="{{ path('app_cart') }}" style="color: #ffffff;"><i class="fas fa-shopping-cart me-2"></i>Mon panier</a></li>
                            <li><a class="dropdown-item" href="{{ path('app_order') }}" style="color: #ffffff;"><i class="fas fa-shopping-bag me-2"></i>Faire une commande</a></li>
                            <li><hr class="dropdown-divider" style="border-color: #333;"></li>
                            <li><a class="dropdown-item" href="{{ path('app_orders_show', {'type': 'all'}) }}" style="color: #ffffff;"><i class="fas fa-history me-2"></i>Historique des commandes</a></li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('app_logout') }}" class="nav-link" style="color: #ffffff; font-weight: 500;">
                            <i class="fas fa-sign-out-alt me-1"></i> Se déconnecter
                        </a>
                    </li>
                {% endif %}

                <!-- Dropdown Commandes avec icône -->
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#" role="button" aria-haspopup="true" aria-expanded="false" style="color: #ffffff; font-weight: 500;">
                        <i class="fas fa-clipboard-list me-1"></i> Commandes
                    </a>
                    <ul class="dropdown-menu" style="background-color: #1a1a1a; border: none;">
                        <li><a class="dropdown-item" href="{{ path('app_orders_show', {'type': 'all'}) }}" style="color: #ffffff;"><i class="fas fa-list me-2"></i>Toutes les commandes</a></li>
                        <li><a class="dropdown-item" href="{{ path('app_orders_show', {'type': 'is-completed'}) }}" style="color: #ffffff;"><i class="fas fa-check-circle me-2"></i>Commandes livrées</a></li>
                        <li><a class="dropdown-item" href="{{ path('app_orders_show', {'type': 'is-not-completed'}) }}" style="color: #ffffff;"><i class="fas fa-times-circle me-2"></i>Commandes non livrées</a></li>
                        <li><a class="dropdown-item" href="{{ path('app_orders_show', {'type': 'pay-on-stripe-is-delivered'}) }}" style="color: #ffffff;"><i class="fas fa-credit-card me-2"></i>Commandes payées en ligne livrées</a></li>
                        <li><a class="dropdown-item" href="{{ path('app_orders_show', {'type': 'pay-on-stripe-not-delivered'}) }}" style="color: #ffffff;"><i class="fas fa-credit-card me-2"></i>Commandes payées en ligne non livrées</a></li>
                    </ul>
                </li>

                <!-- Liens Connexion/Inscription (si utilisateur non connecté) -->
                {% if app.user == false %}
                    <li class="nav-item">
                        <a href="{{ path('app_register') }}" class="nav-link" style="color: #ffffff; font-weight: 500;">
                            <i class="fas fa-user-plus me-1"></i> S'inscrire
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('app_login') }}" class="nav-link" style="color: #ffffff; font-weight: 500;">
                            <i class="fas fa-sign-in-alt me-1"></i> Se connecter
                        </a>
                    </li>
                {% endif %}
            </ul>
            <a href="{{ path('app_cart') }}" class="position-relative me-3" style="color: #d4af37;">
                <i class="fas fa-shopping-cart fa-lg"></i>
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 10px; padding: 0.3em 0.5em;"></span>
            </a>

            <!-- Barre de recherche -->
            <form data-turbo="false" method="GET" action="{{ path('app_search_engine') }}" class="d-flex" role="search">
                <input name="word" class="form-control me-2" type="search" placeholder="Rechercher un produit" aria-label="Search" style="
                    border-radius: 0;
                    border: 1px solid #333;
                    background-color: #ffffff;
                    color: #333333;
                    
                ">
                <button class="btn" type="submit" style="
                    background-color: #d4af37;
                    color: #ffffff;
                    border: none;
                    border-radius: 0;
                    font-weight: 500;
                ">
                    <i class="fas fa-search me-1"></i> Rechercher
                </button>
            </form>
        </div>
    </div>
</nav>

