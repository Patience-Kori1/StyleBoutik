{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}

<div style="
    min-height:80vh; display:flex;
    align-items:center; justify-content:center;
    padding:3rem 1.5rem;
">
    <div style="width:100%; max-width:420px;">

        {# Logo centré #}
        <div style="text-align:center; margin-bottom:2.5rem;">
            <a href="{{ path('app_home_page') }}" style="
                font-family:var(--font-display);
                font-size:2.2rem; font-weight:300;
                color:var(--gold); letter-spacing:4px;
                text-decoration:none;
            ">StyleBoutik</a>
            <div style="width:60px;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);margin:1rem auto;"></div>
            <p style="font-size:.7rem;letter-spacing:3px;text-transform:uppercase;color:var(--white-dim);">
                Connexion à votre compte
            </p>
        </div>

        {# Formulaire #}
        <div style="background:var(--black-card);border:1px solid var(--black-border);padding:2rem;">

            {% if error %}
                <div style="
                    background:rgba(192,57,43,.1);
                    border-left:3px solid var(--danger);
                    padding:12px 16px; margin-bottom:1.5rem;
                    font-size:.85rem; color:#e07065;
                    display:flex;align-items:center;gap:8px;
                ">
                    <i class="fas fa-exclamation-triangle"></i>
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <form method="post" style="display:flex;flex-direction:column;gap:1.25rem;">

                {# Email #}
                <div>
                    <label class="sb-form-label" for="inputEmail">
                        <i class="fas fa-envelope" style="color:var(--gold);margin-right:6px;"></i>
                        Adresse e-mail
                    </label>
                    <input
                        type="email"
                        id="inputEmail"
                        name="_username"
                        value="{{ last_username }}"
                        class="sb-form-control"
                        placeholder="votre@email.com"
                        autocomplete="email"
                        required
                    >
                </div>

                {# Mot de passe #}
                <div>
                    <label class="sb-form-label" for="inputPassword">
                        <i class="fas fa-lock" style="color:var(--gold);margin-right:6px;"></i>
                        Mot de passe
                    </label>
                    <input
                        type="password"
                        id="inputPassword"
                        name="_password"
                        class="sb-form-control"
                        placeholder="••••••••"
                        autocomplete="current-password"
                        required
                    >
                </div>

                {# Se souvenir de moi #}
                <div style="display:flex;align-items:center;gap:8px;">
                    <input type="checkbox" id="remember_me" name="_remember_me"
                           style="accent-color:var(--gold);width:16px;height:16px;">
                    <label for="remember_me" style="font-size:.8rem;color:var(--white-muted);cursor:pointer;">
                        Se souvenir de moi
                    </label>
                </div>

                {# Token CSRF #}
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                {# Bouton connexion #}
                <button type="submit" class="btn-gold filled" style="width:100%;justify-content:center;padding:14px;">
                    <i class="fas fa-sign-in-alt"></i> Se connecter
                </button>

            </form>

        </div>

        {# Lien inscription #}
        <p style="text-align:center;margin-top:1.5rem;font-size:.8rem;color:var(--white-dim);">
            Pas encore de compte ?
            <a href="{{ path('app_register') }}" style="color:var(--gold);">Créer un compte</a>
        </p>

    </div>
</div>

{% endblock %}
