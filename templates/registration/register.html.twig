{% extends 'base.html.twig' %}

{% block title %}Créer un compte{% endblock %}

{% block body %}

<div style="
    min-height:80vh; display:flex;
    align-items:center; justify-content:center;
    padding:3rem 1.5rem;
">
    <div style="width:100%; max-width:480px;">

        {# Logo centré #}
        <div style="text-align:center; margin-bottom:2.5rem;">
            <a href="{{ path('app_home_page') }}" style="
                font-family:var(--font-display);
                font-size:2.2rem; font-weight:300;
                color:var(--gold); letter-spacing:4px;
                text-decoration:none;
            ">StyleBoutik</a>
            <div style="width:60px;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);margin:1rem auto;"></div>
            <p style="font-size:.7rem;letter-spacing:3px;text-transform:uppercase;color:var(--white-dim);">
                Rejoindre la boutique
            </p>
        </div>

        {# Formulaire #}
        <div style="background:var(--black-card);border:1px solid var(--black-border);padding:2rem;">

            {{ form_errors(registrationForm) }}

            {{ form_start(registrationForm, {'attr': {'style': 'display:flex;flex-direction:column;gap:1.25rem;'}}) }}

                {# Prénom #}
                <div>
                    <label class="sb-form-label">
                        <i class="fas fa-user" style="color:var(--gold);margin-right:6px;"></i>
                        Prénom
                    </label>
                    {{ form_widget(registrationForm.firstName, {
                        'attr': {'class': 'sb-form-control', 'placeholder': 'Votre prénom'}
                    }) }}
                    {{ form_errors(registrationForm.firstName) }}
                </div>

                {# Nom #}
                <div>
                    <label class="sb-form-label">
                        <i class="fas fa-user" style="color:var(--gold);margin-right:6px;"></i>
                        Nom
                    </label>
                    {{ form_widget(registrationForm.lastName, {
                        'attr': {'class': 'sb-form-control', 'placeholder': 'Votre nom'}
                    }) }}
                    {{ form_errors(registrationForm.lastName) }}
                </div>

                {# Email #}
                <div>
                    <label class="sb-form-label">
                        <i class="fas fa-envelope" style="color:var(--gold);margin-right:6px;"></i>
                        Adresse e-mail
                    </label>
                    {{ form_widget(registrationForm.email, {
                        'attr': {'class': 'sb-form-control', 'placeholder': 'votre@email.com'}
                    }) }}
                    {{ form_errors(registrationForm.email) }}
                </div>

                {# Mot de passe #}
                <div>
                    <label class="sb-form-label">
                        <i class="fas fa-lock" style="color:var(--gold);margin-right:6px;"></i>
                        Mot de passe
                    </label>
                    {{ form_widget(registrationForm.plainPassword, {
                        'attr': {'class': 'sb-form-control', 'placeholder': '8 caractères minimum'}
                    }) }}
                    {{ form_errors(registrationForm.plainPassword) }}
                </div>

                {# Bouton inscription #}
                <button type="submit" class="btn-gold filled" style="width:100%;justify-content:center;padding:14px;margin-top:.5rem;">
                    <i class="fas fa-user-plus"></i> Créer mon compte
                </button>

            {{ form_end(registrationForm) }}

        </div>

        {# Lien connexion #}
        <p style="text-align:center;margin-top:1.5rem;font-size:.8rem;color:var(--white-dim);">
            Déjà un compte ?
            <a href="{{ path('app_login') }}" style="color:var(--gold);">Se connecter</a>
        </p>

    </div>
</div>

{% endblock %}
