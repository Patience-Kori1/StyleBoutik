{% extends 'base.html.twig' %}
{% block title %}Historique des commandes{% endblock %}

{% block body %}

<div style="max-width:1200px;margin:0 auto;padding:3rem 1.5rem;">

    {# En-tête #}
    <div style="text-align:center;margin-bottom:2.5rem;">
        <p class="sb-section-tag">— Gestion —</p>
        <h1 class="sb-section-title">Historique des commandes</h1>
        <div class="sb-divider"></div>
    </div>

    {# Filtres rapides #}
    <div style="display:flex;gap:.5rem;flex-wrap:wrap;margin-bottom:2rem;justify-content:center;">
        {% set filters = [
            {'type': 'all',                        'label': 'Toutes',              'icon': 'fa-list'},
            {'type': 'is-completed',               'label': 'Livrées',             'icon': 'fa-check-circle'},
            {'type': 'is-not-completed',           'label': 'Non livrées',         'icon': 'fa-times-circle'},
            {'type': 'pay-on-stripe-is-delivered', 'label': 'Stripe livrées',      'icon': 'fa-credit-card'},
            {'type': 'pay-on-stripe-not-delivered','label': 'Stripe non livrées',  'icon': 'fa-credit-card'},
        ] %}
        {% for f in filters %}
            <a href="{{ path('app_orders_show', {'type': f.type}) }}"
               class="btn-gold {% if type == f.type %}filled{% endif %}"
               style="padding:8px 16px;font-size:.7rem;">
                <i class="fas {{ f.icon }}"></i> {{ f.label }}
            </a>
        {% endfor %}
    </div>

    {% if orders|length > 0 %}

        {# Liste des commandes #}
        <div style="display:flex;flex-direction:column;gap:1rem;">
            {% for order in orders %}
                <div style="
                    background:var(--black-card);
                    border:1px solid var(--black-border);
                    padding:1.5rem;
                    transition:var(--transition);
                " onmouseover="this.style.borderColor='var(--gold)'" onmouseout="this.style.borderColor='var(--black-border)'">

                    {# En-tête commande #}
                    <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;margin-bottom:1rem;padding-bottom:1rem;border-bottom:1px solid var(--black-border);">

                        <div>
                            <span style="font-family:var(--font-display);font-size:1.1rem;color:var(--white);">
                                Commande #{{ order.id }}
                            </span>
                            <span style="color:var(--white-dim);font-size:.8rem;margin-left:12px;">
                                {{ order.createdAt|date('d/m/Y à H:i') }}
                            </span>
                        </div>

                        <div style="display:flex;gap:.5rem;align-items:center;flex-wrap:wrap;">
                            {# Badge paiement #}
                            {% if order.payOnDelivery %}
                                <span class="sb-badge sb-badge-gold">
                                    <i class="fas fa-truck"></i> Livraison
                                </span>
                            {% else %}
                                {% if order.isPaymentCompleted %}
                                    <span class="sb-badge sb-badge-success">
                                        <i class="fas fa-credit-card"></i> Payé Stripe
                                    </span>
                                {% else %}
                                    <span class="sb-badge sb-badge-danger">
                                        <i class="fas fa-clock"></i> En attente
                                    </span>
                                {% endif %}
                            {% endif %}

                            {# Badge livraison #}
                            {% if order.isCompleted %}
                                <span class="sb-badge sb-badge-success">
                                    <i class="fas fa-check"></i> Livré
                                </span>
                            {% else %}
                                <span class="sb-badge" style="background:rgba(192,57,43,.1);color:#e07065;border:1px solid var(--danger);">
                                    <i class="fas fa-clock"></i> En cours
                                </span>
                            {% endif %}
                        </div>
                    </div>

                    {# Infos client + total #}
                    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem;margin-bottom:1rem;">
                        <div>
                            <p style="font-size:.7rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--gold);margin-bottom:4px;">Client</p>
                            <p style="color:var(--white-muted);font-size:.9rem;">{{ order.firstName }} {{ order.lastName }}</p>
                            <p style="color:var(--white-dim);font-size:.8rem;">{{ order.email }}</p>
                        </div>
                        <div>
                            <p style="font-size:.7rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--gold);margin-bottom:4px;">Adresse</p>
                            <p style="color:var(--white-muted);font-size:.9rem;">{{ order.adress }}</p>
                            <p style="color:var(--white-dim);font-size:.8rem;">{{ order.city.name }}</p>
                        </div>
                        <div>
                            <p style="font-size:.7rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--gold);margin-bottom:4px;">Total</p>
                            <p style="font-family:var(--font-display);font-size:1.5rem;color:var(--gold);font-weight:300;">{{ order.totalPrice }} €</p>
                        </div>
                    </div>

                    {# Produits commandés #}
                    <div style="margin-bottom:1rem;">
                        <p style="font-size:.7rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--gold);margin-bottom:.5rem;">Produits</p>
                        <div style="display:flex;gap:.5rem;flex-wrap:wrap;">
                            {% for item in order.orderedProducts %}
                                <span style="
                                    background:var(--black-hover);
                                    border:1px solid var(--black-border);
                                    padding:4px 10px;
                                    font-size:.78rem;
                                    color:var(--white-muted);
                                ">
                                    {{ item.product.name }} × {{ item.quantity }}
                                </span>
                            {% endfor %}
                        </div>
                    </div>

                    {# Actions #}
                    <div style="display:flex;gap:.75rem;flex-wrap:wrap;">
                        <a href="{{ path('app_bill', {'id': order.id}) }}"
                           class="btn-gold" style="padding:7px 16px;font-size:.7rem;">
                            <i class="fas fa-file-pdf"></i> Facture PDF
                        </a>
                        <a href="{{ path('app_orders_is-completed-update', {'id': order.id}) }}"
                           class="btn-gold" style="padding:7px 16px;font-size:.7rem;">
                            {% if order.isCompleted %}
                                <i class="fas fa-times"></i> Marquer non livré
                            {% else %}
                                <i class="fas fa-check"></i> Marquer livré
                            {% endif %}
                        </a>
                        <a href="{{ path('app_orders_remove', {'id': order.id}) }}"
                           class="btn-danger-sb" style="padding:7px 16px;font-size:.7rem;"
                           onclick="return confirm('Supprimer cette commande ?')">
                            <i class="fas fa-trash"></i> Supprimer
                        </a>
                    </div>

                </div>
            {% endfor %}
        </div>

        {# Pagination #}
        <div style="margin-top:2rem;">
            {{ knp_pagination_render(orders) }}
        </div>

    {% else %}

        <div style="text-align:center;padding:4rem;border:1px solid var(--black-border);">
            <i class="fas fa-clipboard-list" style="font-size:2.5rem;color:var(--gold);display:block;margin-bottom:1rem;opacity:.4;"></i>
            <h2 style="font-size:1.5rem;font-weight:300;">Aucune commande</h2>
            <p style="color:var(--white-dim);margin-top:.5rem;">Aucune commande ne correspond à ce filtre.</p>
        </div>

    {% endif %}

</div>

{% endblock %}
