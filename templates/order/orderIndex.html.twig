{% extends 'base.html.twig' %}

{% block title %}Passer une commande{% endblock %}

{% block body %}

<div style="max-width:1100px; margin:0 auto; padding:3rem 1.5rem;">

    {# En-tête #}
    <div style="text-align:center; margin-bottom:3rem;">
        <p class="sb-section-tag">✦ Finaliser votre achat ✦</p>
        <h1 class="sb-section-title">Votre commande</h1>
        <div class="sb-divider"></div>
    </div>

    {% if total > 0 %}

        <div style="display:grid; grid-template-columns:1.4fr 1fr; gap:2rem; align-items:start;">

            {# ── Formulaire de livraison ── #}
            <div style="background:var(--black-card); border:1px solid var(--black-border); padding:2rem;">

                <h2 style="font-size:1.3rem; font-weight:300; margin-bottom:1.5rem; padding-bottom:1rem; border-bottom:1px solid var(--black-border);">
                    <i class="fas fa-map-marker-alt" style="color:var(--gold); margin-right:8px; font-size:.9rem;"></i>
                    Informations de livraison
                </h2>

                {{ form_start(form, {'attr': {'id': 'order-form'}}) }}

                <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-bottom:1rem;">
                    {# Prénom #}
                    <div>
                        <label class="sb-form-label">Prénom</label>
                        {{ form_widget(form.firstName, {'attr': {'class': 'sb-form-control', 'placeholder': 'Prénom'}}) }}
                        {{ form_errors(form.firstName) }}
                    </div>
                    {# Nom #}
                    <div>
                        <label class="sb-form-label">Nom</label>
                        {{ form_widget(form.lastName, {'attr': {'class': 'sb-form-control', 'placeholder': 'Nom'}}) }}
                        {{ form_errors(form.lastName) }}
                    </div>
                </div>

                {# Téléphone #}
                <div style="margin-bottom:1rem;">
                    <label class="sb-form-label">Téléphone</label>
                    {{ form_widget(form.phone, {'attr': {'class': 'sb-form-control', 'placeholder': '+33 6 00 00 00 00'}}) }}
                    {{ form_errors(form.phone) }}
                </div>

                {# Adresse #}
                <div style="margin-bottom:1rem;">
                    <label class="sb-form-label">Adresse de livraison</label>
                    {{ form_widget(form.adress, {'attr': {'class': 'sb-form-control', 'placeholder': '12 rue de la Paix'}}) }}
                    {{ form_errors(form.adress) }}
                </div>

                {# Email #}
                <div style="margin-bottom:1rem;">
                    <label class="sb-form-label">Email (pour confirmation)</label>
                    {{ form_widget(form.email, {'attr': {'class': 'sb-form-control', 'placeholder': 'votre@email.com'}}) }}
                    {{ form_errors(form.email) }}
                </div>

                {# Ville #}
                <div style="margin-bottom:1rem;">
                    <label class="sb-form-label">
                        <i class="fas fa-city" style="color:var(--gold);margin-right:6px;"></i>
                        Ville de livraison
                    </label>
                    {{ form_widget(form.city, {'attr': {'class': 'sb-form-control', 'id': 'order_city'}}) }}
                    {{ form_errors(form.city) }}
                </div>

                {# Mode de paiement #}
                <div style="margin-bottom:1.5rem;">
                    <label class="sb-form-label">
                        <i class="fas fa-credit-card" style="color:var(--gold);margin-right:6px;"></i>
                        Mode de paiement
                    </label>
                    <div style="display:flex; gap:1rem; margin-top:.5rem;">

                        {# Option : Paiement à la livraison #}
                        <label style="
                            flex:1; border:1px solid var(--black-border);
                            padding:1rem; cursor:pointer;
                            transition:var(--transition);
                            display:flex; align-items:center; gap:10px;
                        " id="label-delivery" onmouseover="this.style.borderColor='var(--gold)'" onmouseout="updateLabelStyle()">
                            {{ form_widget(form.payOnDelivery, {'attr': {'id': 'pay_on_delivery', 'style': 'accent-color:var(--gold);'}}) }}
                            <div>
                                <div style="font-size:.8rem; font-weight:500; color:var(--white);">
                                    <i class="fas fa-truck" style="color:var(--gold);margin-right:6px;"></i>
                                    Paiement à la livraison
                                </div>
                                <div style="font-size:.7rem; color:var(--white-dim); margin-top:2px;">
                                    Payez à la réception
                                </div>
                            </div>
                        </label>

                    </div>
                    {{ form_errors(form.payOnDelivery) }}
                </div>

                {# Bouton soumettre #}
                <button type="submit" class="btn-gold filled" style="width:100%;justify-content:center;padding:14px;">
                    <i class="fas fa-check"></i> Confirmer la commande
                </button>

                {{ form_end(form) }}

            </div>

            {# ── Récapitulatif commande ── #}
            <div style="position:sticky; top:80px;">

                {# Produits du panier #}
                <div style="background:var(--black-card); border:1px solid var(--black-border); padding:1.5rem; margin-bottom:1rem;">
                    <h2 style="font-size:1.1rem; font-weight:300; margin-bottom:1rem; padding-bottom:.75rem; border-bottom:1px solid var(--black-border);">
                        <i class="fas fa-shopping-bag" style="color:var(--gold);margin-right:8px;font-size:.9rem;"></i>
                        Récapitulatif
                    </h2>

                    {# Total produits #}
                    <div style="display:flex; justify-content:space-between; margin-bottom:.75rem;">
                        <span style="color:var(--white-muted); font-size:.85rem;">Produits</span>
                        <span style="font-family:var(--font-display); font-size:1.1rem; color:var(--white);">
                            <span id="card-price">{{ total }}</span> €
                        </span>
                    </div>

                    {# Frais de livraison (mis à jour par AJAX) #}
                    <div style="display:flex; justify-content:space-between; margin-bottom:.75rem; align-items:center;">
                        <span style="color:var(--white-muted); font-size:.85rem;">Livraison</span>
                        <span style="font-family:var(--font-display); font-size:1.1rem; color:var(--gold);">
                            <span id="shippingCost">—</span>
                            <span id="shipping-unit" style="font-size:.8rem; display:none;"> €</span>
                        </span>
                    </div>

                    <div style="height:1px; background:linear-gradient(90deg,transparent,var(--gold),transparent); margin:1rem 0;"></div>

                    {# Total général #}
                    <div style="display:flex; justify-content:space-between; align-items:baseline;">
                        <span style="font-size:.75rem; letter-spacing:2px; text-transform:uppercase; color:var(--white-muted);">Total</span>
                        <span style="font-family:var(--font-display); font-size:1.8rem; color:var(--gold); font-weight:300;">
                            <span class="total_Price">{{ total }}</span> €
                        </span>
                    </div>

                    <p id="shipping-info" style="font-size:.72rem; color:var(--white-dim); text-align:center; margin-top:.75rem; letter-spacing:.5px;">
                        Frais calculés selon la ville choisie
                    </p>
                </div>

                {# Info sécurité #}
                <div style="
                    border:1px solid var(--black-border);
                    padding:1rem;
                    background:var(--gold-subtle);
                    text-align:center;
                ">
                    <i class="fas fa-lock" style="color:var(--gold);margin-right:6px;"></i>
                    <span style="font-size:.75rem;color:var(--white-muted);letter-spacing:.5px;">
                        Paiement 100% sécurisé
                    </span>
                </div>

            </div>

        </div>

    {% else %}

        {# Panier vide #}
        <div style="text-align:center;padding:4rem;border:1px solid var(--black-border);">
            <i class="fas fa-shopping-bag" style="font-size:3rem;color:var(--gold);display:block;margin-bottom:1rem;opacity:.5;"></i>
            <h2 style="font-size:1.5rem;font-weight:300;margin-bottom:.75rem;">Votre panier est vide</h2>
            <p style="color:var(--white-dim);margin-bottom:2rem;">Ajoutez des produits avant de passer commande.</p>
            <a href="{{ path('app_home_page') }}" class="btn-gold filled">
                <i class="fas fa-arrow-right"></i> Voir le catalogue
            </a>
        </div>

    {% endif %}

</div>

{% endblock %}

{% block javascripts %}
{# jQuery via CDN pour l'appel AJAX du prix de livraison #}
<script src="https://code.jquery.com/jquery-3.7.1.min.js" crossorigin="anonymous"></script>
<script>
$(document).ready(function() {
    const citySelector = $('#order_city');
    const cardPrice    = parseInt($('#card-price').text());

    /**
     * Met à jour l'affichage des frais de livraison et du total
     * en appelant la route /city/{id}/shipping/cost via AJAX
     */
    function updateShipping(cityId) {
        if (!cityId) return;

        $.ajax({
            url: `/city/${cityId}/shipping/cost`,
            type: 'GET',
            success: function(response) {
                const data = JSON.parse(response);
                if (parseInt(data.status) === 200) {
                    const shippingCost = parseInt(data.content);
                    // Mise à jour des éléments d'affichage
                    $('#shippingCost').text(shippingCost);
                    $('#shipping-unit').show();
                    $('.total_Price').text(cardPrice + shippingCost);
                    $('#shipping-info').hide();
                }
            },
            error: function() {
                $('#shippingCost').text('Erreur');
            }
        });
    }

    // Mise à jour initiale au chargement
    updateShipping(citySelector.val());

    // Mise à jour à chaque changement de ville
    citySelector.on('change', function() {
        updateShipping($(this).val());
    });

    function updateLabelStyle() {
        // Réinitialise la bordure si non coché
        const label = document.getElementById('label-delivery');
        if (label) label.style.borderColor = 'var(--black-border)';
    }
});
</script>
{% endblock %}
