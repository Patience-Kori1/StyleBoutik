{% extends 'base.html.twig' %}
{% block title %}Gestion des utilisateurs{% endblock %}

{% block body %}
<div style="max-width:1000px;margin:0 auto;padding:3rem 1.5rem;">

    <div style="margin-bottom:2rem;">
        <p class="sb-section-tag" style="text-align:left;">— Admin —</p>
        <h1 style="font-family:var(--font-display);font-size:2rem;font-weight:300;">Utilisateurs</h1>
    </div>

    <div style="border:1px solid var(--black-border);">
        <table class="sb-table">
            <thead>
                <tr>
                    <th>Utilisateur</th>
                    <th>Email</th>
                    <th>Rôles</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                    <tr>
                        <td style="color:var(--white);">
                            {{ user.firstName }} {{ user.lastName }}
                        </td>
                        <td style="color:var(--white-muted);font-size:.85rem;">{{ user.email }}</td>
                        <td>
                            <div style="display:flex;gap:.4rem;flex-wrap:wrap;">
                                {% for role in user.roles %}
                                    {% if role == 'ROLE_ADMIN' %}
                                        <span class="sb-badge" style="background:rgba(201,168,76,.2);color:var(--gold);border:1px solid var(--gold);">
                                            <i class="fas fa-crown"></i> Admin
                                        </span>
                                    {% elseif role == 'ROLE_EDITOR' %}
                                        <span class="sb-badge sb-badge-gold">
                                            <i class="fas fa-edit"></i> Éditeur
                                        </span>
                                    {% elseif role == 'ROLE_USER' %}
                                        <span class="sb-badge" style="background:rgba(39,174,96,.1);color:#6ee297;border:1px solid #27ae60;">
                                            <i class="fas fa-user"></i> User
                                        </span>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </td>
                        <td>
                            <div style="display:flex;gap:.5rem;flex-wrap:wrap;">
                                {# Promouvoir éditeur #}
                                {% if 'ROLE_EDITOR' not in user.roles %}
                                    <a href="{{ path('app_user_to_editor', {'id': user.id}) }}"
                                       class="btn-gold" style="padding:6px 12px;font-size:.68rem;"
                                       title="Promouvoir éditeur">
                                        <i class="fas fa-arrow-up"></i> Éditeur
                                    </a>
                                {% else %}
                                    <a href="{{ path('app_user_remove_editor_role', {'id': user.id}) }}"
                                       class="btn-gold" style="padding:6px 12px;font-size:.68rem;"
                                       title="Retirer rôle éditeur">
                                        <i class="fas fa-arrow-down"></i> Retirer
                                    </a>
                                {% endif %}
                                {# Supprimer #}
                                <a href="{{ path('app_user_remove', {'id': user.id}) }}"
                                   class="btn-danger-sb" style="padding:6px 12px;font-size:.68rem;"
                                   onclick="return confirm('Supprimer cet utilisateur ?')">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" style="text-align:center;padding:3rem;color:var(--white-dim);">
                            Aucun utilisateur enregistré.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
